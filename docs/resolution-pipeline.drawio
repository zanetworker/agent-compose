<mxfile>
  <diagram name="Resolution Pipeline" id="pipeline">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="850" background="none">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Background -->
        <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=none;opacity=100;" vertex="1" parent="1">
          <mxGeometry x="-50" y="-50" width="1200" height="920" as="geometry"/>
        </mxCell>

        <!-- Title -->
        <mxCell id="title" value="Resolution Pipeline" style="text;html=1;fontSize=24;fontStyle=1;fontColor=#151515;fontFamily=Red Hat Display;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="0" width="400" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Agent config to openshell commands in 12 steps" style="text;html=1;fontSize=13;fontStyle=2;fontColor=#6A6A6A;fontFamily=Red Hat Text;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="35" width="400" height="25" as="geometry"/>
        </mxCell>

        <!-- INPUT: Agent Config -->
        <mxCell id="input_box" value="&lt;b&gt;Agent Config&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#6A6A6A;font-family:Red Hat Mono&quot;&gt;runtime: claude-code&lt;br&gt;inference: maas&lt;br&gt;mcp: [github]&lt;br&gt;prompt: &quot;Review this code&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5F5;strokeColor=#EE0000;strokeWidth=2;fontColor=#151515;fontFamily=Red Hat Text;fontSize=12;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="20" y="80" width="220" height="90" as="geometry"/>
        </mxCell>

        <!-- Steps 1-12 -->
        <mxCell id="s1" value="&lt;font style=&quot;color:#EE0000;font-weight:bold&quot;&gt;1&lt;/font&gt;  &lt;b&gt;Load agent config&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#6A6A6A&quot;&gt;config.yaml agents section, file, or CLI flags&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#D0D0D0;fontColor=#151515;fontFamily=Red Hat Text;fontSize=11;arcSize=8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="80" width="320" height="42" as="geometry"/>
        </mxCell>

        <mxCell id="s2" value="&lt;font style=&quot;color:#EE0000;font-weight:bold&quot;&gt;2&lt;/font&gt;  &lt;b&gt;Apply defaults + overrides&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#6A6A6A&quot;&gt;inference, model, policy, sandbox scope/mode/ttl&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#D0D0D0;fontColor=#151515;fontFamily=Red Hat Text;fontSize=11;arcSize=8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="132" width="320" height="42" as="geometry"/>
        </mxCell>

        <mxCell id="s3" value="&lt;font style=&quot;color:#EE0000;font-weight:bold&quot;&gt;3&lt;/font&gt;  &lt;b&gt;Resolve runtime&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#6A6A6A&quot;&gt;image, entrypoint, env-mapping template, default tools&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5F5;strokeColor=#EE0000;strokeWidth=2;fontColor=#151515;fontFamily=Red Hat Text;fontSize=11;arcSize=8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="184" width="320" height="42" as="geometry"/>
        </mxCell>

        <mxCell id="s4" value="&lt;font style=&quot;color:#EE0000;font-weight:bold&quot;&gt;4&lt;/font&gt;  &lt;b&gt;Resolve inference + expand N-var&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#6A6A6A&quot;&gt;${endpoint}/${key}/${model}/${model.opus} to env vars&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5F5;strokeColor=#EE0000;strokeWidth=2;fontColor=#151515;fontFamily=Red Hat Text;fontSize=11;arcSize=8;align=left;spacingLeft=10;" vertex="1" parent="1">
