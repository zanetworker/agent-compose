        <mxCell id="s6" value="&lt;font style=&quot;color:#EE0000;font-weight:bold&quot;&gt;6&lt;/font&gt;  &lt;b&gt;Resolve each skill&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#6A6A6A&quot;&gt;prompt text, required MCP, required tools, mounts&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#D0D0D0;fontColor=#151515;fontFamily=Red Hat Text;fontSize=11;arcSize=8;align=left;spacingLeft=10;" vertex="1" parent="1">
