        <mxCell id="s7" value="&lt;font style=&quot;color:#EE0000;font-weight:bold&quot;&gt;7&lt;/font&gt;  &lt;b&gt;Assemble prompt&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#6A6A6A&quot;&gt;agent prompt + skill prompts&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#D0D0D0;fontColor=#151515;fontFamily=Red Hat Text;fontSize=11;arcSize=8;align=left;spacingLeft=10;" vertex="1" parent="1">
